# Sogni Account Credentials
# Copy this file to .env and fill in your credentials
#
# Option 1: API Key (recommended)
# SOGNI_API_KEY=your_api_key_here
#
# Option 2: Username/Password
SOGNI_USERNAME=your_username_here
SOGNI_PASSWORD=your_password_here

# Payment Token Type (sogni or spark)
# Uncomment and set to skip the payment type prompt
# SOGNI_TOKEN_TYPE=spark
